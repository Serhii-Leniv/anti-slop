{
  "hooks": [
    {
      "event": "PostToolUse",
      "matcher": "Write|Edit",
      "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scan.py",
      "timeout": 8000
    },
    {
      "event": "SessionStart",
      "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/load_profile.py",
      "timeout": 5000
    }
  ]
}
